{
  "name": "cedric-ragot-sonotherapie-render",
  "version": "1.0.0",
  "type": "module",
  "description": "Site de sonothérapie - Production Ready pour Render",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "dev:server": "NODE_ENV=development node --loader tsx server/index.ts",
    "dev:client": "cd client && vite",
    "build": "pnpm run build:client && pnpm run build:server",
    "build:client": "cd client && vite build",
    "build:server": "esbuild server/index.ts --platform=node --target=node20 --format=cjs --bundle --outfile=dist/server/index.cjs",
    "start": "NODE_ENV=production node dist/server/index.cjs",
    "preview": "cd client && vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.38.0",
    "clsx": "^2.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "esbuild": "^0.19.11",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "terser": "^5.46.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.7",
    "vitest": "^1.0.4"
  }
}
